9:["$","h3",null,{"className":"font-[family-name:var(--font-playfair)] text-xl font-semibold text-[var(--text)] mb-3","children":"Measurement & Pattern"}]
a:["$","p",null,{"className":"text-[var(--muted)] text-sm leading-relaxed","children":"Precision is the foundation of a perfect fit. We take a comprehensive set of measurements — bust, waist, hips, height, shoulder width, sleeve length, and more — and use them to draft a custom pattern built exclusively for your body. No standard sizing. No compromises. Every curve and contour is accounted for."}]
b:["$","div","03",{"className":"bg-[var(--bg-secondary)] rounded-[18px] p-8 border border-[var(--border)]","children":[["$","div",null,{"className":"font-[family-name:var(--font-playfair)] text-4xl font-bold text-[var(--brand)] opacity-40 mb-4","children":"03"}],["$","h3",null,{"className":"font-[family-name:var(--font-playfair)] text-xl font-semibold text-[var(--text)] mb-3","children":"Fabric Sourcing"}],["$","p",null,{"className":"text-[var(--muted)] text-sm leading-relaxed","children":"We believe the right fabric is half the garment. Working from our curated network of premium textile suppliers, we source ethically produced fabrics that honour both your design and the craft. From duchess satin and hand-beaded lace to structured crepe and fluid chiffon — every material is chosen with intention."}]]}]
c:["$","div","04",{"className":"bg-[var(--bg-secondary)] rounded-[18px] p-8 border border-[var(--border)]","children":[["$","div",null,{"className":"font-[family-name:var(--font-playfair)] text-4xl font-bold text-[var(--brand)] opacity-40 mb-4","children":"04"}],["$","h3",null,{"className":"font-[family-name:var(--font-playfair)] text-xl font-semibold text-[var(--text)] mb-3","children":"Construction & Fittings"}],["$","p",null,{"className":"text-[var(--muted)] text-sm leading-relaxed","children":"Your garment is built by hand in our Lagos atelier. Couture techniques — French seams, hand-stitched hems, boning, and custom linings — are applied throughout. We schedule one to two fitting sessions during construction so adjustments are made on your body, not on a dress form. The result is a garment that moves with you."}]]}]
