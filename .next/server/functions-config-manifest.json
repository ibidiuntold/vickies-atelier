{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!_next\\/webpack-hmr).*))(\\.json)?[\\/#\\?]?$",
          "originalSource": "/((?!_next/webpack-hmr).*)"
